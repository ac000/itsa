# Copy this file into someplace like
#
#   /etc/bash_completion.d/ or
#   ~/.bash_completion.d/
#
# This should then get picked up by new shells.
# You can load it in current shells with 'source itsa'

_itsa()
{
	local cur prev
	local cmd

	cur=${COMP_WORDS[COMP_CWORD]}
	prev=${COMP_WORDS[COMP_CWORD-1]}

	cmd=${COMP_WORDS[0]}

	case ${COMP_CWORD} in
	1)
		COMPREPLY=($(compgen -W "$(${prev} | tail -n +5 | cut -d " " -f 5)" -- ${cur}))
		;;
	*)
		COMPREPLY=()
		;;
	esac
}
complete -o bashdefault -o default -F _itsa itsa ./itsa
